# Plantilla de variables de entorno de viahost-web.
# Copia este fichero a `.env` y rellena los valores reales. NO commitees `.env`.

# --- Obligatorias en producción ---------------------------------------------

# Secreto para firmar las cookies de sesión (HMAC-SHA256).
# Genera uno fuerte, p. ej.:  openssl rand -hex 32
# Si falta en producción, la app falla en cerrado (no arranca sesiones inseguras).
AUTH_SECRET=

# Emails con acceso al panel /admin. Lista separada por comas.
ADMIN_EMAILS=admin@example.com

# --- Opcionales -------------------------------------------------------------

# Reenvío de leads (contacto/pedidos) por POST a un webhook (Slack, n8n, CRM…).
# LEADS_WEBHOOK_URL=

# --- Pasarela de pago (webhook /api/webhooks/payments) ----------------------
# Mientras estas variables no estén definidas, el webhook responde 503 e inerte.

# Proveedor activo: "stripe" (de momento el implementado). Vacío = desactivado.
# PAYMENTS_PROVIDER=stripe

# Secreto de firma del endpoint de webhook de Stripe (Dashboard → Webhooks).
# STRIPE_WEBHOOK_SECRET=whsec_xxx
